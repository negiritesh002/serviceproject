PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/servicebooking
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRE=7d
NODE_ENV=development

# Firebase Phone OTP
FIREBASE_PROJECT_ID=your_project_id

# For Email notifications (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Twilio SMS is only used for optional booking notifications, not OTP
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+1234567890

FRONTEND_URL=http://localhost:3000
# Optional: comma-separated list of additional allowed browser origins
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
